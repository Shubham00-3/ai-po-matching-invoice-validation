# ── LLM (invoice extraction — Step 2) ───────────────
# Put the REAL key only in n8n's encrypted credentials or a gitignored .env — never in a committed file.
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1-nano        # cheapest reliable tier; bump to gpt-4o-mini if extraction misses on messy invoices
# Call with Structured Outputs: response_format = { type: "json_schema", strict: true, ... } → guaranteed valid JSON

# ── Airtable ────────────────────────────────────────
# Personal Access Token: https://airtable.com/create/tokens
# Scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_PO_TABLE=Purchase_Orders
AIRTABLE_PO_LINES_TABLE=PO_Line_Items
AIRTABLE_INVOICES_TABLE=Invoices
AIRTABLE_INVOICE_LINES_TABLE=Invoice_Line_Items
AIRTABLE_AUDIT_TABLE=Audit_Log

# ── Email (Gmail or IMAP) ───────────────────────────
# In n8n these are stored as CREDENTIALS, not env vars. Listed here for reference.
PROCUREMENT_INBOX=procurement@yourdomain.com

# ── Matching / validation rules (Steps 4-6) ─────────
# Names match the CONFIG block in docs/MATCHING_ENGINE.md (read via $env in the Code node).
MONEY_REL_TOLERANCE_PCT=2        # ±% allowed on money (net / tax / total / unit price)
TAX_ABS_TOLERANCE_CENTS=2        # absolute rounding slack on recomputed tax (cents)
TAX_REL_CEILING_CENTS=500        # max absolute $ the relative tax band may forgive (cents)
TOTAL_ABS_TOLERANCE_CENTS=2      # slack on the Net + Tax = Gross identity (cents)
# Quantity is matched EXACTLY by default. Outcome bands:
#   0 discrepancies -> Ready for Payment | only minor -> Procurement Review | any major -> Rejected

# ── Behavior flags (referenced in sample-data/SAMPLE_DATA.md) ──
TREAT_MISSING_PO_AS_REVIEW=false # true = unknown PO routes to Procurement Review instead of Rejected
DUPLICATE_POLICY=flag            # flag = create record marked duplicate | skip = don't create a second record
OCR_ENABLED=false                # true = run OCR fallback on scanned/no-text-layer PDFs (bonus)

# ── Notifications (optional bonus) ──────────────────
SLACK_WEBHOOK_URL=
PROCUREMENT_TEAM_EMAIL=procurement-team@yourdomain.com
